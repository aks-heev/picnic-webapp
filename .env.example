# Copy to .env.local and fill in. .env.local is gitignored.
# Only VITE_* vars are exposed to the browser bundle.

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
VITE_ADMIN_EMAIL=<admin@example.com>

# Razorpay publishable key id (safe for the client).
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# PostHog analytics (safe for the client — this is a project API key, not a secret).
# Get it from posthog.com → your project → Settings → Project API Key.
# Leave blank (or omit) to disable analytics entirely (e.g. local dev without tracking).
# For EU cloud use: VITE_POSTHOG_HOST=https://eu.posthog.com
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://app.posthog.com

# ---------------------------------------------------------------------------
# SERVER-SIDE ONLY — do NOT put these in .env.local or any VITE_ variable.
# Set them as Supabase Edge Function secrets so they reach create-order /
# verify-payment but never the browser:
#
#   supabase secrets set RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
#   supabase secrets set RAZORPAY_KEY_SECRET=your_key_secret
# ---------------------------------------------------------------------------
